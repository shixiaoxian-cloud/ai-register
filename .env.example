HEADED=true
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/Los_Angeles
ACCEPT_LANGUAGE=en-US,en;q=0.9
LOCAL_BROWSER_NAME=chrome
# Optional: set a full browser path to override auto-detection
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CONFIG_UI_PORT=3200
CONTINUE_AFTER_PROTECTED_CHALLENGE=false
MANUAL_STEP_TIMEOUT_MS=300000

# Anti-detection configuration
# STEALTH_MODE: Enable anti-detection scripts (true/false)
# TELEMETRY_MODE: Telemetry request handling mode (block/modify/log/allow)
#   - block: Completely block telemetry requests
#   - modify: Modify requests to remove sensitive fingerprints
#   - log: Log requests but allow them to be sent
#   - allow: Allow all telemetry requests
STEALTH_MODE=true
TELEMETRY_MODE=block

# Email configuration - Choose ONE method:
# Method 1: Use temporary email service (recommended for automation)
USE_TEMP_MAIL=true
TEMP_MAIL_BASE_URL=http://114.215.173.42:888
TEMP_MAIL_API_KEY=tm_admin_36f53ee440748349007538fde32d1aeeb3ac028c804d7b90

# Keep temporary mailbox after test (for debugging)
# true = Keep mailbox, you can view it in tempmail backend
# false = Auto-delete after test (default)
KEEP_TEMP_MAILBOX=false

# Method 2: Use existing email with IMAP (traditional method)
# Set USE_TEMP_MAIL=false to use this method
TARGET_EMAIL=
TARGET_PASSWORD=

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
EMAIL_CODE_REGEX=\b(\d{6})\b
EMAIL_POLL_INTERVAL_MS=5000
EMAIL_TIMEOUT_MS=180000

# Token output configuration
# Directory to save extracted tokens (CPA and Sub2Api formats)
TOKEN_OUTPUT_DIR=./output_tokens

# DuckDNS configuration (optional - for temporary domain testing)
# Get your token from: https://www.duckdns.org/
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=
